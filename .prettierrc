{
  "semi": true,
  "singleQuote": true,
  "htmlWhitespaceSensitivity": "css",
  "printWidth": 100,
  "plugins": ["prettier-plugin-organize-imports", "prettier-plugin-tailwindcss"],
  "tailwindFunctions": ["clsx", "cn"],
  "tailwindStylesheet": "./src/index.css",
  "trailingComma": "all",
  "tabWidth": 2
}
